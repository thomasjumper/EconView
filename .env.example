# ── FRED ──────────────────────────────────────────────────
FRED_API_KEY=your_fred_key_here
# 120 requests/minute free tier. Get key: https://fred.stlouisfed.org/docs/api/api_key.html

# ── FINNHUB ───────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
# 60 REST requests/minute, 50 WebSocket symbols max, 1 WS connection per key
# WebSocket URL: wss://ws.finnhub.io?token=YOUR_API_KEY
FINNHUB_WS_SYMBOLS_LIMIT=50

# ── ALPHA VANTAGE ─────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_av_key_here
# ⚠️ WARNING: FREE TIER = 25 REQUESTS/DAY. Use ONLY for one-time historical data loads.

# ── COINGECKO ─────────────────────────────────────────────
COINGECKO_API_KEY=your_cg_demo_key_here
# Demo (free) plan: 30 calls/minute, 10,000 calls/month cap. Poll every 5 minutes.

# ── FINANCIAL MODELING PREP ───────────────────────────────
FMP_API_KEY=your_fmp_key_here
# Free tier: 250 requests/day.

# ── SEC EDGAR ─────────────────────────────────────────────
SEC_EDGAR_USER_AGENT=EconView/1.0 your@email.com

# ── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── SERVER ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
